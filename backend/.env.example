# === Promopage Videos — backend ===

# Porta da API (frontend faz proxy /api -> aqui)
PORT=4020

# CORS: vazio = libera tudo (dev). Em prod: https://videos.promopage.com.br
CORS_ORIGIN=

# URL pública da API. O render (headless chrome) busca imagens/áudios por aqui.
# Dev: http://localhost:4020 (default). Prod: https://videos.promopage.com.br
PUBLIC_BASE_URL=

# Quantos renders simultâneos a fila in-process processa.
# Render de vídeo é pesado (CPU). 1 é seguro em máquina modesta.
RENDER_CONCURRENCY=1

# --- Storage ---
# local (default) = salva em backend/out. Em prod: r2 ou b2 (driver futuro).
STORAGE_DRIVER=local

# --- IA opcional (deixe vazio pra desligar) ---
# Texto de CTA / chamadas (OpenAI). Sem chave, usa textos padrão do segmento.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Narração de intro/encerramento/CTA (ElevenLabs). Sem chave, vídeo 100% escrito.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
